# Copy this file to ".env" and fill it in, OR just export these in your shell.
# This file (and .env) must NEVER be committed. .gitignore covers it.
#
# mailmerge reads your password from the environment at run time. The same Gmail
# App Password is used for BOTH sending (SMTP) and reading replies (IMAP).
#
#   macOS / Linux:
#     export EMAIL_APP_PASSWORD='your-16-char-app-password'
#
#   Windows PowerShell:
#     $env:EMAIL_APP_PASSWORD='your-16-char-app-password'
#
# For Gmail you must use an App Password (not your normal password):
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:       https://myaccount.google.com/apppasswords
#   3. Use the 16-character value below.

EMAIL_APP_PASSWORD=your-app-password-here
